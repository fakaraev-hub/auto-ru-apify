{
  "title": "Auto.ru Parser Config",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "mode": {
      "title": "Mode",
      "type": "string",
      "description": "search, card, or monitor",
      "default": "search"
    },
    "searchUrl": {
      "title": "Search URL",
      "type": "string",
      "default": ""
    },
    "offerUrls": {
      "title": "Offer URLs (comma-separated)",
      "type": "string",
      "default": ""
    },
    "brand": {
      "title": "Brand",
      "type": "string",
      "default": ""
    },
    "model": {
      "title": "Model",
      "type": "string",
      "default": ""
    },
    "priceMin": {
      "title": "Min Price",
      "type": "integer",
      "default": 0
    },
    "priceMax": {
      "title": "Max Price",
      "type": "integer",
      "default": 0
    },
    "yearMin": {
      "title": "Min Year",
      "type": "integer",
      "default": 0
    },
    "yearMax": {
      "title": "Max Year",
      "type": "integer",
      "default": 0
    },
    "city": {
      "title": "City",
      "type": "string",
      "default": ""
    },
    "maxPages": {
      "title": "Max Pages",
      "type": "integer",
      "default": 3
    }
  },
  "required": ["mode"]
}
